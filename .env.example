# Frontend environment variables for HVAC Quote AI.
# Quote generation and email sending should run through Supabase Edge Functions.

VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side secrets belong in Supabase, not in the frontend:
# OPENAI_API_KEY=...
# OPENAI_MODEL=gpt-5-mini
# RESEND_API_KEY=...
# RESEND_FROM_EMAIL=quotes@hvacquote.pro
